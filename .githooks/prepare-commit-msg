#!/bin/sh
# Strips Cursor IDE's automatic Co-authored-by trailer so shared history stays
# under team authorship only. Enable once per clone:
#   git config core.hooksPath .githooks
MSG_FILE="$1"
if [ -z "$MSG_FILE" ] || [ ! -f "$MSG_FILE" ]; then
    exit 0
fi
TMP="${MSG_FILE}.stripcursor"
grep -v '^Co-authored-by: Cursor ' "$MSG_FILE" > "$TMP" && mv "$TMP" "$MSG_FILE"
exit 0
